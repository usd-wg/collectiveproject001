#usda 1.0
(
    defaultPrim = "main"
    endTimeCode = 1
    metersPerUnit = 0.01
    startTimeCode = 1
    upAxis = "Y"
)

over "main"
{
    over "geo"
    {
        over "room" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </main/mtl/terrain>
        }

        over "pCube1" (
            prepend apiSchemas = ["MaterialBindingAPI"]
        )
        {
            rel material:binding = </main/mtl/cube>
        }
    }
}

